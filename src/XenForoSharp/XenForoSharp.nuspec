<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>XenForoSharp</id>
    <version>$version$</version>
    <title>XenForoSharp</title>
    <authors>XenForoSharp</authors>
    <owners>XenForoSharp</owners>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <license type="expression">MIT</license>
    <icon>images\package-icon.png</icon>
    <projectUrl>https://github.com/XenForoSharp/XenForoSharp</projectUrl>
    <repository type="git" url="https://github.com/XenForoSharp/XenForoSharp.git" />
    <readme>README.md</readme>
    <description>Typed XenForo API client for .NET Framework 4.8.</description>
    <summary>Route-based XenForo API client with strongly typed models.</summary>
    <releaseNotes>Core XenForo API coverage, typed routes, examples and package metadata.</releaseNotes>
    <tags>xenforo api rest forum dotnet csharp</tags>
    <dependencies>
      <group targetFramework=".NETFramework4.8">
        <dependency id="Microsoft.Bcl.AsyncInterfaces" version="8.0.0" />
        <dependency id="Newtonsoft.Json" version="13.0.1" />
        <dependency id="RestSharp" version="112.1.0" />
        <dependency id="System.Buffers" version="4.5.1" />
        <dependency id="System.Memory" version="4.5.5" />
        <dependency id="System.Numerics.Vectors" version="4.5.0" />
        <dependency id="System.Runtime.CompilerServices.Unsafe" version="6.0.0" />
        <dependency id="System.Text.Encodings.Web" version="8.0.0" />
        <dependency id="System.Text.Json" version="8.0.6" />
        <dependency id="System.Threading.Tasks.Extensions" version="4.5.4" />
        <dependency id="System.ValueTuple" version="4.5.0" />
      </group>
    </dependencies>
  </metadata>
  <files>
    <file src="src\XenForoSharp\bin\$configuration$\XenForoSharp.dll" target="lib\net48" />
    <file src="src\XenForoSharp\bin\$configuration$\XenForoSharp.xml" target="lib\net48" />
    <file src="README.md" />
    <file src="CHANGELOG.md" />
    <file src="LICENSE" />
    <file src="assets\package-icon.png" target="images\" />
    <file src="examples\**\*.*" target="examples" />
  </files>
</package>
